DATABASE_URL='postgresql://{DB_USER}:{DB_PASSWORD}@{DB_HOST}/{DB_NAME}?sslmode=require&channel_binding=require'
UPLOADTHING_TOKEN=
# SHA-256 hex digest of the admin password (never store the plain password).
# Generate on Linux with:  printf '%s' 'your-password' | sha256sum | awk '{print $1}'
ADMIN_PASSWORD=
# Random session-signing secret. Generate with:  openssl rand -hex 32
AUTH_SECRET=
NEXT_PUBLIC_APP_URL='http://localhost:3000'
